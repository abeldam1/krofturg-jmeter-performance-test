        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="List Subscriptions">
          <stringProp name="TestPlan.comments">Created from cURL on 2026-07-19T08:37:08.5991676</stringProp>
          <stringProp name="HTTPSampler.domain">krofturg-vlrm-backend-ce6210296b4e.herokuapp.com</stringProp>
