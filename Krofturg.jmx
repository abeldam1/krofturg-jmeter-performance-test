          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.net.HttpURLConnection
import groovy.json.JsonOutput
import groovy.json.JsonSlurper

def loginUrl = &quot;https://krofturg-vlrm-backend-ce6210296b4e.herokuapp.com/api/auth/client/login&quot;

def conn = (HttpURLConnection) new URL(loginUrl).openConnection()
conn.setRequestMethod(&quot;POST&quot;)
conn.setDoOutput(true)
conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/json&quot;)
conn.setConnectTimeout(30000)
conn.setReadTimeout(30000)

def body = [
    email: &quot;nomsouzoanya@yahoo.co.uk&quot;,
    password: &quot;vicecity&quot;
]

conn.outputStream.withWriter(&quot;UTF-8&quot;) { writer -&gt;
    writer &lt;&lt; JsonOutput.toJson(body)
}

int responseCode = conn.responseCode

def response = (responseCode &gt;= 200 &amp;&amp; responseCode &lt; 300) ?
        conn.inputStream.getText(&quot;UTF-8&quot;) :
        conn.errorStream.getText(&quot;UTF-8&quot;)

log.info(&quot;Login Response Code: ${responseCode}&quot;)
log.info(&quot;Login Response: ${response}&quot;)

if (responseCode == 200) {
    def json = new JsonSlurper().parseText(response)

    // Save values as JMeter variables
    vars.put(&quot;token&quot;, json.data.token.toString())
    vars.put(&quot;refreshToken&quot;, json.data.refreshToken.toString())
    vars.put(&quot;uId&quot;, json.data.uId.toString())

    log.info(&quot;Token saved as variable &apos;token&apos;&quot;)
    log.info(&quot;Token = ${vars.get(&apos;token&apos;)}&quot;)

} else {
    throw new Exception(&quot;Login failed: ${response}&quot;)
}</stringProp>
          </JSR223PreProcessor>
