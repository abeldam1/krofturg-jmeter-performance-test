      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.net.HttpURLConnection
import groovy.json.JsonOutput
import groovy.json.JsonSlurper

// Refresh after 2 minutes
long REFRESH_INTERVAL = 120000L

long now = System.currentTimeMillis()

// Synchronize so only one thread refreshes
synchronized(props) {

    long lastLogin = (props.get(&quot;lastLoginTime&quot;) ?: &quot;0&quot;) as long

    if ((now - lastLogin) &gt;= REFRESH_INTERVAL) {

        log.info(&quot;Refreshing authentication token...&quot;)

        def conn = (HttpURLConnection) new URL(
            &quot;https://krofturg-vlrm-backend-ce6210296b4e.herokuapp.com/api/auth/client/login&quot;
        ).openConnection()

        conn.setRequestMethod(&quot;POST&quot;)
        conn.setDoOutput(true)
        conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/json&quot;)

        def body = [
            email: &quot;nomsouzoanya@yahoo.co.uk&quot;,
            password: &quot;vicecity&quot;
        ]

        conn.outputStream.withWriter(&quot;UTF-8&quot;) {
            it &lt;&lt; JsonOutput.toJson(body)
        }

        if (conn.responseCode == 200) {

            def response = conn.inputStream.getText(&quot;UTF-8&quot;)
            def json = new JsonSlurper().parseText(response)

            props.put(&quot;token&quot;, json.data.token.toString())
            props.put(&quot;refreshToken&quot;, json.data.refreshToken.toString())
            props.put(&quot;lastLoginTime&quot;, System.currentTimeMillis().toString())

            log.info(&quot;Token refreshed successfully.&quot;)

        } else {

            log.error(&quot;Token refresh failed. HTTP &quot; + conn.responseCode)

        }
    }
}

// Make the current token available as a JMeter variable
vars.put(&quot;token&quot;, props.get(&quot;token&quot;))</stringProp>
        </JSR223PreProcessor>
